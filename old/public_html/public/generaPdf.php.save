$appUrl = rtrim($_ENV['APP_URL'] ?? getenv('APP_URL') ?? 'http://localhost', '/');

// Read DB config from env
$dbHost = getenv('DB_HOST') ?: 'localhost';
$dbUser = getenv('DB_USERNAME') ?: 'root';
$dbPass = getenv('DB_PASSWORD') ?: '';
$dbDatabase = getenv('DB_DATABASE') ?: '';
$dbPort = getenv('DB_PORT') ? (int) getenv('DB_PORT') : ini_get("mysqli.default_port");

// Create mysqli connection (DB selection is done below by existing code)
$mysqli = new mysqli($dbHost, $dbUser, $dbPass, null, $dbPort ?: null);
if ($mysqli->connect_errno) {
    die('Errore connessione al DB: ' . $mysqli->connect_error);
}
// cnx a la base
mysqli_select_db($mysqli, $dbDatabase) or die('Errore connessione al DB: ' .mysqli_connect_error());

