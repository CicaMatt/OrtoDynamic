            FROM item_preventivi ip
            LEFT JOIN nomenclatore n ON n.id = ip.codice_nomenclatore
            WHERE ip.id_preventivo = ' . $checkedValue;
    $resultItems = mysqli_query($mysqli, $sqlItems);
    if($resultItems){
        while ($row = $resultItems->fetch_assoc()) {
            $items[] = $row;
        }
        mysqli_free_result($resultItems);
    }

    $templatePath = './doc/ddt.pdf';
    if (file_exists($templatePath)) {
        $pdf = new FPDI();
        $pdf->AddPage();
        $pdf->setSourceFile($templatePath);
        $tplIdx = $pdf->importPage(1);
        $pdf->useTemplate($tplIdx, 5, 5, 200);
    } else {
        $pdf = new FPDF();
        $pdf->AddPage();
    }

    $ddtNumber = !empty($preventivo['numero_ordine']) ? $preventivo['numero_ordine'] : (!empty($preventivo['numero_preventivo']) ? $preventivo['numero_preventivo'] : $checkedValue);
    $destinatario = trim($preventivo['cognome'].' '.$preventivo['nome']);
    $indirizzoCompleto = trim($preventivo['indirizzo'].' - '.$preventivo['cap'].' '.$preventivo['citta'].' ('.$preventivo['provincia'].')');

    $pdf->SetFont('Arial','B',14);
    $pdf->Cell(0,8,utf8_decode('Documento di trasporto'),0,1,'C');
    $pdf->Ln(2);
    $pdf->SetFont('Arial','',10);
    $pdf->Cell(35,6,utf8_decode('DDT n°:'),0,0);
    $pdf->Cell(80,6,utf8_decode($ddtNumber),0,0);
    $pdf->Cell(35,6,utf8_decode('Data:'),0,0);
    $pdf->Cell(0,6,date('d/m/Y'),0,1);
    if(!empty($preventivo['numero_autorizzazione'])){
        $pdf->Cell(35,6,utf8_decode('Autorizzazione:'),0,0);
        $pdf->Cell(80,6,utf8_decode($preventivo['numero_autorizzazione']),0,1);
    } else {
        $pdf->Ln(6);
    }
    $pdf->Ln(2);
    $pdf->SetFont('Arial','B',11);
    $pdf->Cell(0,6,utf8_decode('Destinatario'),0,1);
    $pdf->SetFont('Arial','',10);
    $pdf->Cell(0,6,utf8_decode($destinatario),0,1);
    if($indirizzoCompleto){
        $pdf->Cell(0,6,utf8_decode($indirizzoCompleto),0,1);
    }
    $pdf->Ln(4);

    $pdf->SetFont('Arial','B',9);
    $pdf->Cell(30,7,utf8_decode('Codice'),1,0,'L');
    $pdf->Cell(80,7,utf8_decode('Descrizione'),1,0,'L');
    $pdf->Cell(20,7,utf8_decode('Qtà'),1,0,'C');
    $pdf->Cell(30,7,utf8_decode('Prezzo'),1,0,'R');
    $pdf->Cell(30,7,utf8_decode('Importo'),1,1,'R');

    $pdf->SetFont('Arial','',9);
    $totale = 0;
    if(count($items)){
        foreach($items as $item){
            $codice = isset($item['codice']) ? $item['codice'] : '';
            $descrizione = isset($item['descrizione']) ? $item['descrizione'] : '';
            if(function_exists('mb_strimwidth')){
                $descrizione = mb_strimwidth($descrizione, 0, 55, '...', 'UTF-8');
            } else {
                $descrizione = (strlen($descrizione) > 55) ? substr($descrizione, 0, 55).'...' : $descrizione;
            }
            $quantityValue = isset($item['quantita']) ? (float) $item['quantita'] : 0;
            $quantitaFormatted = ($quantityValue == (int)$quantityValue) ? (string)(int)$quantityValue : number_format($quantityValue, 2, ',', '.');
            $prezzoValue = isset($item['prezzo']) ? (float)$item['prezzo'] : 0;
            $prezzo = $prezzoValue ? number_format($prezzoValue, 2, ',', '.') . ' ' . chr(128) : '';
            $importoVal = isset($item['importo']) && $item['importo'] !== null ? (float)$item['importo'] : ($prezzoValue * $quantityValue);
            $importo = $importoVal ? number_format($importoVal, 2, ',', '.') . ' ' . chr(128) : '';
            $totale += $importoVal;

            $pdf->Cell(30,7,utf8_decode($codice),1,0,'L');
            $pdf->Cell(80,7,utf8_decode($descrizione),1,0,'L');
            $pdf->Cell(20,7,utf8_decode($quantitaFormatted),1,0,'C');
            $pdf->Cell(30,7,utf8_decode($prezzo),1,0,'R');
            $pdf->Cell(30,7,utf8_decode($importo),1,1,'R');
        }
    } else {
        $pdf->Cell(190,7,utf8_decode('Nessuna voce disponibile'),1,1,'C');
    }

    $pdf->SetFont('Arial','B',9);
    $pdf->Cell(160,7,utf8_decode('Totale'),1,0,'R');
    $pdf->Cell(30,7,utf8_decode(number_format($totale, 2, ',', '.') . ' ' . chr(128)),1,1,'R');

    if(!empty($preventivo['note'])){
        $pdf->Ln(5);
        $pdf->SetFont('Arial','B',10);
        $pdf->Cell(0,6,utf8_decode('Note'),0,1);
        $pdf->SetFont('Arial','',9);
        $pdf->MultiCell(0,5,utf8_decode($preventivo['note']));
    }

    $pdf->Output('I', 'ddt_'.$checkedValue.'.pdf');
    exit;

