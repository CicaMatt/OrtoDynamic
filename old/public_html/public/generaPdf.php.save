            INNER JOIN clienti ON clienti.id = preventivi.id_cliente
            WHERE preventivi.id = ' . $checkedValue . ' LIMIT 1';

    $result = mysqli_query($mysqli, $sql)  or die ('Errore SQL : ' .$sql .mysqli_connect_error() );
