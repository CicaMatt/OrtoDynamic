<?php
// Carico l'autoload di Composer (se presente)
$vendorAutoload = __DIR__ . '/vendor/autoload.php';
if (file_exists($vendorAutoload)) {
    require_once $vendorAutoload;

    // Se la libreria Dotenv è presente, la inizializzo in modo compatibile
    if (class_exists('Dotenv\Dotenv')) {
        // phpdotenv v3+ ha createImmutable(), v2 usa il costruttore
        if (method_exists('Dotenv\Dotenv', 'createImmutable')) {
            $dotenv = Dotenv\Dotenv::createImmutable(__DIR__);
            // Preferiamo safeLoad se disponibile per non fallire se .env manca
            if (method_exists($dotenv, 'safeLoad')) {
                $dotenv->safeLoad();
            } else {
                $dotenv->load();
            }
        } else {
            // fallback per phpdotenv v2.x
            try {
                $dotenv = new Dotenv\Dotenv(__DIR__);
                $dotenv->load();
            } catch (Throwable $e) {
                // non blockiamo l'esecuzione se il caricamento fallisce
            }
        }
    }
}

// librerie FPDF/FPDI (assumo che siano file locali come prima)
require_once('fpdf.php');
