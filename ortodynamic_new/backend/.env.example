# Copy to `.env` for local development and fill in real values.
# Never commit the real `.env`.

# --- Django core ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=Europe/Rome

# --- Database (the already-existing SQL database) ---
# For MySQL/MariaDB use: django.db.backends.mysql
DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_NAME=ortodynamic
DJANGO_DB_USER=ortodynamic
DJANGO_DB_PASSWORD=
DJANGO_DB_HOST=localhost
DJANGO_DB_PORT=5432
DJANGO_DB_CONN_MAX_AGE=60

# --- CORS (frontend origins allowed to call the API) ---
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173
